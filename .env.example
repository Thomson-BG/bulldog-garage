# Cloudflare R2 Configuration
# After setting up your R2 bucket, add its public URL here.
# Example: https://pub-abc123def456.r2.dev

R2_PUBLIC_URL=https://your-r2-public-url-here.r2.dev

# Note: This is optional. You can also edit player.html directly
# and replace YOUR_R2_PUBLIC_URL with your actual public URL.
